<Window x:Class="ImportadorDeGTINEAN.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:ImportadorDeGTINEAN.Desktop.Converters"
        xmlns:vm="clr-namespace:ImportadorDeGTINEAN.Desktop.ViewModels"
        Title="Configurações - PostgreSQL"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}">

    <Window.DataContext>
        <vm:SettingsViewModel />
    </Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter" />
    </Window.Resources>

    <Grid>
        <materialDesign:Card Margin="20" Padding="24">
            <StackPanel>
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <materialDesign:PackIcon Kind="DatabaseCog" Width="28" Height="28"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                                             VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBlock Text="Conexão PostgreSQL"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Host -->
                <TextBox materialDesign:HintAssist.Hint="Servidor (IP ou hostname)"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <!-- Port -->
                <TextBox materialDesign:HintAssist.Hint="Porta"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <!-- Database -->
                <TextBox materialDesign:HintAssist.Hint="Banco de Dados"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <!-- User -->
                <TextBox materialDesign:HintAssist.Hint="Usuário"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding User, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <!-- Password with toggle -->
                <Grid Margin="0,0,0,16">
                    <PasswordBox x:Name="PasswordBoxField"
                                 materialDesign:HintAssist.Hint="Senha"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 Visibility="{Binding ShowPassword, Converter={StaticResource InverseBoolToVisConverter}}" />
                    <TextBox materialDesign:HintAssist.Hint="Senha"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVisConverter}}" />
                    <ToggleButton Style="{StaticResource MaterialDesignFlatToggleButton}"
                                  IsChecked="{Binding ShowPassword}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Margin="0,0,4,0" Width="32" Height="32"
                                  ToolTip="Mostrar/ocultar senha"
                                  Click="TogglePassword_Click">
                        <materialDesign:PackIcon Width="20" Height="20">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="EyeOff" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowPassword}" Value="True">
                                            <Setter Property="Kind" Value="Eye" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                    </ToggleButton>
                </Grid>

                <!-- Test Connection -->
                <DockPanel Margin="0,0,0,20">
                    <Button DockPanel.Dock="Left" Command="{Binding TestConnectionCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LanConnect" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Testar Conexão" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Width="24" Height="24" Margin="12,0,0,0"
                                 Visibility="{Binding IsTesting, Converter={StaticResource BoolToVisConverter}}" />
                    <TextBlock Text="{Binding TestResult}" VerticalAlignment="Center" Margin="12,0,0,0"
                               TextWrapping="Wrap" FontSize="13" />
                </DockPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="CANCELAR" Click="Cancel_Click"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="0,0,8,0" />
                    <Button Content="SALVAR" Click="Save_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="4" />
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
